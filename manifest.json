{
  "manifest_version": 3,
  "name": "ChatGPT Page Relay Prototype",
  "description": "Experimental local relay from selected webpage text into an open ChatGPT tab.",
  "version": "0.1.0",
  "minimum_chrome_version": "116",
  "permissions": [
    "activeTab",
    "contextMenus",
    "scripting",
    "sidePanel",
    "storage",
    "tabs"
  ],
  "optional_host_permissions": [
    "http://localhost:11434/*"
  ],
  "host_permissions": [
    "https://chatgpt.com/*",
    "https://chat.openai.com/*"
  ],
  "background": {
    "service_worker": "background/service-worker.js",
    "type": "module"
  },
  "side_panel": {
    "default_path": "sidepanel/sidepanel.html"
  },
  "action": {
    "default_title": "Open ChatGPT relay panel"
  }
}
